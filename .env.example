# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Postgres / Prisma — copy the FULL string from Supabase → Settings → Database → Connection string.
#
# For Vercel (and most serverless): choose "Transaction pooler" (or "Session pooler").
#   Host looks like: aws-0-REGION.pooler.supabase.com  port 6543
#
# WRONG (will fail): db.xxxxx.supabase.co:6543  ← port 6543 does NOT go on the db.* host.
# Direct host is only for port 5432: db.xxxxx.supabase.co:5432
#
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true

# Local: http://localhost:3000 | Production: https://your-domain.vercel.app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# After first deploy, apply migrations from a machine that can reach Postgres (e.g. your laptop):
#   npm run db:migrate
# (Uses DATABASE_URL from .env — direct or pooler is fine locally.)
