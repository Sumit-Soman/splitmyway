# Copy to .env.local in this folder (tests/e2e/.env.local) — not committed.
# The app root .env is also loaded for DATABASE_URL / Supabase URL.

E2E_BASE_URL=http://127.0.0.1:3000

# Primary actor (creates group, expenses)
E2E_USER_A_EMAIL=testuser@test.com
E2E_USER_A_PASSWORD=Test@123

# Second member (settlements, expenses)
E2E_USER_B_EMAIL=cooanju@gmail.com
E2E_USER_B_PASSWORD=Test@123

# Optional: auto-provision both users in Supabase Auth + Prisma before tests.
# Requires service role key (never expose to browsers / client bundles).
SUPABASE_SERVICE_ROLE_KEY=
