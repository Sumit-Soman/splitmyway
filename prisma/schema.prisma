generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  avatarUrl String?  @map("avatar_url")
  currency  String   @default("USD")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  groupMemberships      GroupMember[]
  paidExpenses          Expense[]
  expenseParticipations ExpenseParticipant[]
  settlementsFrom       Settlement[]   @relation("settler")
  settlementsTo         Settlement[]   @relation("settlee")
  activityLogs          ActivityLog[]
  invitationsSent       Invitation[]   @relation("inviter")

  @@map("users")
}

model Group {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String   @default("other")
  currency    String   @default("USD")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members      GroupMember[]
  expenses     Expense[]
  settlements  Settlement[]
  invitations  Invitation[]
  activityLogs ActivityLog[]

  @@map("groups")
}

model GroupMember {
  id       String   @id @default(uuid())
  userId   String   @map("user_id")
  groupId  String   @map("group_id")
  role     String   @default("member")
  joinedAt DateTime @default(now()) @map("joined_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@map("group_members")
}

model Invitation {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  email     String?
  token     String   @unique @default(uuid())
  status    String   @default("pending")
  invitedBy String   @map("invited_by")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inviter User  @relation("inviter", fields: [invitedBy], references: [id], onDelete: Cascade)

  @@map("invitations")
}

model Expense {
  id               String   @id @default(uuid())
  groupId          String   @map("group_id")
  paidById         String   @map("paid_by_id")
  description      String
  amount           Decimal  @db.Decimal(12, 2)
  currency         String   @default("USD")
  originalAmount   Decimal? @db.Decimal(12, 2) @map("original_amount")
  originalCurrency String?  @map("original_currency")
  exchangeRate     Decimal? @db.Decimal(18, 8) @map("exchange_rate")
  category         String   @default("general")
  date             DateTime @default(now())
  notes            String?
  receiptUrl       String?  @map("receipt_url")
  splitMethod      String   @default("equal") @map("split_method")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  group        Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy       User                @relation(fields: [paidById], references: [id], onDelete: Cascade)
  participants ExpenseParticipant[]

  @@map("expenses")
}

model ExpenseParticipant {
  id         String  @id @default(uuid())
  expenseId  String  @map("expense_id")
  userId     String  @map("user_id")
  amount     Decimal @db.Decimal(12, 2)
  shares     Int?
  percentage Decimal? @db.Decimal(5, 2)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expenseId, userId])
  @@map("expense_participants")
}

model Settlement {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  fromId    String   @map("from_id")
  toId      String   @map("to_id")
  amount    Decimal  @db.Decimal(12, 2)
  currency  String   @default("USD")
  notes     String?
  settledAt DateTime @default(now()) @map("settled_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  from  User  @relation("settler", fields: [fromId], references: [id], onDelete: Cascade)
  to    User  @relation("settlee", fields: [toId], references: [id], onDelete: Cascade)

  @@map("settlements")
}

model ActivityLog {
  id        String   @id @default(uuid())
  groupId   String?  @map("group_id")
  userId    String   @map("user_id")
  type      String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  group Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activity_logs")
}
